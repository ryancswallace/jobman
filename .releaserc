---
# Semantic-release owns version calculation, the v-prefixed Git tag, and the
# GitHub release notes. GoReleaser subsequently stages artifacts in that draft,
# and the release workflow publishes it only after provenance succeeds.
branches:
  - main

tagFormat: "v${version}"

# Listing plugins explicitly prevents the default npm publishing step from
# running in this Go-only repository.
plugins:
  - "@semantic-release/commit-analyzer"
  - "@semantic-release/release-notes-generator"
  - - "@semantic-release/github"
    - draftRelease: true
      releaseNameTemplate: "<%= nextRelease.gitTag %>"
      successCommentCondition: false
      failCommentCondition: false
      releasedLabels: false
